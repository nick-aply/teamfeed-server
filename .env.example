# Aply server environment variables
# Copy to .env and fill in real values. Never commit .env.

# ===== Firebase Admin =====
FIREBASE_PRIVATE_KEY=

# ===== OpenAI =====
OPENAI_API_KEY=

# ===== SendGrid =====
SENDGRID_API_KEY=

# ===== Stripe =====
# TeamFeed LLC's Stripe dashboard. Use sk_test_... for development.
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe Price ID for the $99 application deposit (Phase 3a — Aply Specialist Program).
# Find/create this in Stripe Dashboard → Products → "Aply Specialist Program — Deposit".
STRIPE_PRICE_ID_DEPOSIT=price_replace_me

# Stripe Price ID for the $400 balance charged on acceptance (Phase 4a). Not
# used by /api/stripe/charge-balance directly (it passes amount=40000 to the
# off-session PaymentIntent), but tracked here for parity / future migration.
STRIPE_PRICE_ID_BALANCE=price_1TTqjMCVe3vHv7annEACeNpA

# Where Stripe redirects after successful payment.
# Final destination is the post-payment "application in review" page on Aply.
STRIPE_SUCCESS_URL=https://aply.com/pipeline/sorority-rush-specialists?paid=1

# Where Stripe redirects if the user cancels checkout.
STRIPE_CANCEL_URL=https://teamfeed.co/pay/sorority-rush-specialists?canceled=1

# Stripe webhook signing secret (Phase 3c). Get this from Stripe Dashboard →
# Developers → Webhooks → (your endpoint) → "Signing secret". Starts with whsec_.
# Without this, the /webhooks/stripe route rejects all events.
STRIPE_WEBHOOK_SECRET=
